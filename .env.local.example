# ==============================================================
# .env.local.example — Template for local environment files
# Copy to .env.local (prod) or .env.e2e.local (demo/E2E)
# ==============================================================

# ── Vite (browser-side, VITE_ prefix required) ───────────────
VITE_SUPABASE_URL = https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY = <anon-key>
VITE_RPC_SECRET = <vault-rpc-secret>

# ── Demo mode (only in .env.e2e.local) ───────────────────────
# VITE_DEMO_MODE = true
# VITE_DEMO_ADMIN_EMAIL = <demo-admin-email>
# VITE_DEMO_ADMIN_PASSWORD = <demo-admin-password>
# VITE_DEMO_ENTRY_TOKEN = <entry-token>
# VITE_DEMO_BYPASS_UIDS = <comma-separated-uids>

# ── Supabase Edge Function secrets ───────────────────────────
# Set via: supabase secrets set --project-ref <ref>
# Also kept here as local reference.

SUPABASE_URL = https://<project-ref>.supabase.co
SUPABASE_ANON_KEY = <anon-key>
SUPABASE_SERVICE_ROLE_KEY = <service-role-key>
SUPABASE_DB_URL = postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
RPC_SECRET = <vault-rpc-secret>

NOTIFICATION_FROM = VERA <noreply@vera-eval.app>
NOTIFICATION_LOGO_URL = https://<project-ref>.supabase.co/storage/v1/object/public/vera_logo/vera_logo_dark.png
NOTIFICATION_APP_URL = https://<your-domain>
NOTIFICATION_REVIEW_URL = https://<your-domain>

DEMO_MODE = false
# DEMO_BYPASS_UIDS = <comma-separated-user-uuids>
ALLOW_WILDCARD_ORIGIN = false
ALLOWED_ORIGINS = http://localhost:5173,https://<your-domain>

# ── GitHub Secrets (synced) ──────────────────────────────────
# These are also set as GitHub repo secrets for CI/CD workflows.

DATABASE_URL = postgresql://postgres:<password>@db.<prod-ref>.supabase.co:5432/postgres
DEMO_DATABASE_URL = postgresql://postgres:<password>@db.<demo-ref>.supabase.co:5432/postgres

SUPABASE_ACCESS_TOKEN = <supabase-personal-access-token>
SUPABASE_PROJECT_REF_DEMO = <demo-project-ref>
SUPABASE_PROJECT_REF_PROD = <prod-project-ref>

NOTIFICATION_REVIEW_URL_DEMO_LOCAL = http://<local-ip>:5173
NOTIFICATION_APP_URL_DEMO_LOCAL = http://<local-ip>:5173
NOTIFICATION_REVIEW_URL_DEMO_VERCEL = https://demo.vera-eval.app
NOTIFICATION_APP_URL_DEMO_VERCEL = https://demo.vera-eval.app
NOTIFICATION_REVIEW_URL_PROD = https://vera-eval.app
NOTIFICATION_APP_URL_PROD = https://vera-eval.app

# ── E2E test credentials ─────────────────────────────────────
E2E_ADMIN_EMAIL = <e2e-admin-email>
E2E_ADMIN_PASSWORD = <e2e-admin-password>
E2E_JUROR_NAME = <test-juror-name>
E2E_JUROR_DEPT = <test-juror-dept>
E2E_JUROR_PIN = <test-juror-pin>
E2E_SEMESTER_NAME = <active-semester-name>
E2E_LOCKED = false
E2E_RPC_SECRET = <vault-rpc-secret>
E2E_SUPABASE_ANON_KEY = <demo-anon-key>
E2E_SUPABASE_URL = https://<demo-project-ref>.supabase.co
