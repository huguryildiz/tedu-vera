# ==============================================================
# .env.e2e.example — E2E / demo testing environment template
# Copy to .env.e2e.local and fill values.
# ==============================================================

# ── App runtime (Vite / Playwright webServer) ────────────────
VITE_SUPABASE_URL=https://<demo-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<demo-anon-key>
VITE_RPC_SECRET=<demo-rpc-secret>

# ── Demo mode ────────────────────────────────────────────────
VITE_DEMO_MODE=true
VITE_DEMO_ADMIN_EMAIL=<demo-admin-email>
VITE_DEMO_ADMIN_PASSWORD=<demo-admin-password>
VITE_DEMO_ENTRY_TOKEN=<demo-entry-token>
VITE_DEMO_BYPASS_UIDS=<comma-separated-uids>

# ── Supabase service keys ────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
RPC_SECRET=<rpc-secret>

# ── Database URLs ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DEMO_DATABASE_URL=postgresql://postgres:<password>@db.<demo-project-ref>.supabase.co:5432/postgres

# ── Playwright test credentials / fixtures ───────────────────
E2E_ADMIN_EMAIL=<e2e-admin-email>
E2E_ADMIN_PASSWORD=<e2e-admin-password>
E2E_JUROR_NAME=<test-juror-name>
E2E_JUROR_DEPT=<test-juror-dept>
E2E_JUROR_PIN=<4-digit-pin>
E2E_SEMESTER_NAME=<active-semester-name>
E2E_LOCKED=false
E2E_RPC_SECRET=<rpc-secret>
E2E_SUPABASE_ANON_KEY=<demo-anon-key>
E2E_SUPABASE_URL=https://<demo-project-id>.supabase.co

# ── Notification / Edge Function config ──────────────────────
NOTIFICATION_APP_URL=https://<demo-domain>
NOTIFICATION_REVIEW_URL=https://<demo-domain>
NOTIFICATION_FROM=VERA <noreply@your-domain>
NOTIFICATION_LOGO_URL=https://<project-ref>.supabase.co/storage/v1/object/public/vera_logo/vera_logo_dark.png

# ── Supabase project management ─────────────────────────────
SUPABASE_ACCESS_TOKEN=<supabase-access-token>
SUPABASE_PROJECT_REF_DEMO=<demo-project-ref>
SUPABASE_PROJECT_REF_PROD=<prod-project-ref>

# ── Edge Function secrets (demo) ────────────────────────────
DEMO_MODE=true
DEMO_BYPASS_UIDS=<comma-separated-uids>
ALLOW_WILDCARD_ORIGIN=true
ALLOWED_ORIGINS=http://localhost:5173,https://<demo-domain>

# ── Optional ─────────────────────────────────────────────────
# E2E_BASE_URL=http://localhost:5173
